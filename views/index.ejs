<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Rental System</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-slate-100 min-h-screen flex flex-col">

    <!-- Navbar -->
    <nav class="bg-white shadow-md border-b border-slate-200 px-8 py-4">
        <div class="flex justify-between items-center max-w-7xl mx-auto">
            <div class="flex items-center gap-3">
                <i data-lucide="car-front" class="w-7 h-7 text-blue-600"></i>
                <h1 class="text-2xl font-bold text-slate-800">DriveSync</h1>
            </div>

            <div class="flex items-center gap-5">
                <a href="/auth/login" class="text-slate-600 hover:text-blue-600 font-semibold transition">Login</a>
                <a href="/auth/register"
                   class="flex items-center gap-2 bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 shadow-md transition">
                    <i data-lucide="user-plus" class="w-4 h-4"></i>
                    Register
                </a>
            </div>
        </div>
    </nav>

    <!-- Main -->
    <main class="max-w-7xl mx-auto py-12 px-6 flex-grow">

        <!-- Hero Section -->
        <div class="bg-white rounded-2xl shadow-lg p-12 text-center mb-16 border border-slate-200">
            <h2 class="text-5xl font-extrabold text-slate-800 mb-6">Find Your Perfect Ride</h2>
            <p class="text-xl text-slate-500 mb-10 max-w-2xl mx-auto">
                Explore our fleet of premium and economy vehicles tailored for every journey. 
                Easy booking, transparent pricing, and 24/7 support.
            </p>
            <div class="flex justify-center gap-4">
                <a href="/auth/login" 
                   class="flex items-center gap-2 bg-blue-600 text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-blue-700 shadow-lg transition">
                    <i data-lucide="rocket" class="w-5 h-5"></i>
                    Get Started Now
                </a>
            </div>
        </div>

        <!-- Feature Grid -->
        <div class="mb-20">
            <div class="flex items-center gap-3 mb-10">
                <i data-lucide="star" class="w-6 h-6 text-orange-500"></i>
                <h3 class="text-2xl font-bold text-slate-800">Why Choose DriveSync?</h3>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition">
                    <i data-lucide="gem" class="w-10 h-10 text-blue-600 mb-4"></i>
                    <h4 class="text-xl font-bold text-slate-800 mb-2">Premium Fleet</h4>
                    <p class="text-slate-500">Access a wide range of top-tier luxury cars and reliable daily drivers.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition">
                    <i data-lucide="shield-check" class="w-10 h-10 text-emerald-600 mb-4"></i>
                    <h4 class="text-xl font-bold text-slate-800 mb-2">Fully Insured</h4>
                    <p class="text-slate-500">Every rental comes with comprehensive insurance for your peace of mind.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition">
                    <i data-lucide="credit-card" class="w-10 h-10 text-purple-600 mb-4"></i>
                    <h4 class="text-xl font-bold text-slate-800 mb-2">Flexible Payments</h4>
                    <p class="text-slate-500">Secure online payments with various methods including UPI and Cards.</p>
                </div>
            </div>
        </div>

        <!-- Workflow Grid -->
        <div class="mb-12">
            <div class="flex items-center gap-3 mb-10">
                <i data-lucide="milestone" class="w-6 h-6 text-indigo-600"></i>
                <h3 class="text-2xl font-bold text-slate-800">How It Works</h3>
            </div>

            <div class="grid md:grid-cols-3 gap-12 relative">
                <div class="text-center">
                    <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">1</div>
                    <h4 class="text-lg font-bold text-slate-800 mb-2">Browse & Select</h4>
                    <p class="text-slate-500">Search through our garage and pick the car that fits your style.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">2</div>
                    <h4 class="text-lg font-bold text-slate-800 mb-2">Confirm Booking</h4>
                    <p class="text-slate-500">Select your dates and confirm your booking instantly.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">3</div>
                    <h4 class="text-lg font-bold text-slate-800 mb-2">Drive Away</h4>
                    <p class="text-slate-500">Pick up your keys and enjoy your journey with total ease.</p>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-slate-800 text-slate-400 text-center py-8 border-t border-slate-700">
        &copy; 2024 DriveSync Rental System
    </footer>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>