<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CarEase Admin Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-slate-100 min-h-screen">

    <!-- Navbar -->
    <nav class="bg-white shadow-md border-b border-slate-200 px-8 py-4 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex justify-between items-center">

            <div class="flex items-center gap-3">
                <i data-lucide="shield-check" class="w-7 h-7 text-blue-600"></i>
                <h1 class="text-2xl font-bold text-slate-800">CarEase Admin</h1>
            </div>

            <div class="flex items-center gap-5">

                <div class="flex items-center gap-2 text-slate-700">
                    <i data-lucide="user-circle" class="w-5 h-5"></i>
                    <span><%= admin.name %></span>
                </div>

                <a href="/car/add"
                   class="flex items-center gap-2 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">
                    <i data-lucide="plus-circle"></i>
                    Add Car
                </a>

                <a href="/auth/logout"
                   class="flex items-center gap-2 bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition">
                    <i data-lucide="log-out"></i>
                    Logout
                </a>

            </div>
        </div>
    </nav>

    <!-- Main -->
    <main class="max-w-7xl mx-auto py-10 px-6">

        <!-- Status Alerts -->
        <div id="status-container" class="mb-6 hidden">
            <div id="status-message" class="p-4 rounded-xl border flex items-center gap-3">
                <i id="status-icon" class="w-5 h-5"></i>
                <span id="status-text" class="font-medium"></span>
            </div>
        </div>
        <script>
            const params = new URLSearchParams(window.location.search);
            const container = document.getElementById('status-container');
            const msg = document.getElementById('status-message');
            const text = document.getElementById('status-text');
            if (params.has('approveBooking_true')) { container.classList.remove('hidden'); msg.classList.add('bg-green-50', 'text-green-700', 'border-green-200'); text.innerText = 'Booking approved successfully!'; }
            if (params.has('approveBooking_false')) { container.classList.remove('hidden'); msg.classList.add('bg-red-50', 'text-red-700', 'border-red-200'); text.innerText = 'Failed to approve booking.'; }
            if (params.has('rejectBooking_true')) { container.classList.remove('hidden'); msg.classList.add('bg-orange-50', 'text-orange-700', 'border-orange-200'); text.innerText = 'Booking rejected and car marked as available.'; }
            if (params.has('rejectBooking_false')) { container.classList.remove('hidden'); msg.classList.add('bg-red-50', 'text-red-700', 'border-red-200'); text.innerText = 'Error processing rejection.'; }
        </script>

        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-8 mb-8 border border-slate-200">
            <div class="flex items-center gap-3 mb-2">
                <i data-lucide="layout-dashboard" class="w-8 h-8 text-blue-600"></i>
                <h2 class="text-3xl font-bold text-slate-800">Admin Control Panel</h2>
            </div>
            <p class="text-slate-500">Manage users, fleet and bookings easily.</p>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

            <!-- User Management -->
            <section class="bg-white p-6 rounded-2xl shadow-md border border-slate-200">
                <div class="flex items-center gap-2 mb-5">
                    <i data-lucide="users" class="text-blue-600"></i>
                    <h3 class="text-xl font-bold text-slate-800">User Management</h3>
                </div>

                <div class="space-y-4">

                    <% users.forEach(user => { %>
                        <div class="flex justify-between items-center p-4 rounded-xl border border-slate-200 bg-slate-50">

                            <div>
                                <p class="font-semibold text-slate-800"><%= user.name %></p>
                                <p class="text-sm <%= user.isDeleted ? 'text-red-500' : 'text-green-500' %>">
                                    <%= user.isDeleted ? 'Deleted' : 'Active' %>
                                </p>
                            </div>

                            <% if (!user.isDeleted) { %>
                                <form action="/secure/delete" method="POST">
                                    <input type="hidden" name="id" value="<%= user._id %>">
                                    <button class="bg-red-500 text-white px-3 py-2 rounded-lg text-sm hover:bg-red-600">
                                        Delete
                                    </button>
                                </form>
                            <% } else { %>
                                <form action="/secure/restore" method="POST">
                                    <input type="hidden" name="id" value="<%= user._id %>">
                                    <button class="bg-green-500 text-white px-3 py-2 rounded-lg text-sm hover:bg-green-600">
                                        Restore
                                    </button>
                                </form>
                            <% } %>

                        </div>
                    <% }) %>

                </div>
            </section>

            <!-- Audit Logs -->
            <section class="bg-white p-6 rounded-2xl shadow-md border border-slate-200">
                <div class="flex items-center gap-2 mb-5">
                    <i data-lucide="file-text" class="text-green-600"></i>
                    <h3 class="text-xl font-bold text-slate-800">Audit Logs</h3>
                </div>

                <div class="space-y-4">

                    <% audits.forEach(audit => { %>
                        <div class="p-4 rounded-xl border-l-4 shadow-sm border <%= audit.action.includes('Success') ? 'border-green-500 bg-green-50' : 'border-red-500 bg-red-50' %>">

                            <div class="flex justify-between">
                                <p class="font-semibold text-slate-800"><%= audit.action %></p>
                                <span class="text-xs text-slate-500"><%= audit.createdAt.toLocaleString() %></span>
                            </div>

                            <p class="text-sm text-slate-500 mt-2">
                                User: <%= audit.user ? audit.user.name : 'Guest' %>
                            </p>

                            <p class="text-xs text-slate-400">
                                IP: <%= audit.ip %> | <%= audit.method %>
                            </p>

                        </div>
                    <% }) %>

                </div>
            </section>

            <!-- Fleet Controls -->
            <section class="bg-white p-6 rounded-2xl shadow-md border border-slate-200">
                <div class="flex items-center gap-2 mb-5">
                    <i data-lucide="car-front" class="text-purple-600"></i>
                    <h3 class="text-xl font-bold text-slate-800">Fleet Controls</h3>
                </div>

                <div class="space-y-4">
                    <a href="/car/add"
                       class="block border-2 border-dashed border-slate-300 rounded-xl p-4 text-center hover:border-blue-500 transition group">
                        <i data-lucide="plus-circle" class="mx-auto w-6 h-6 text-blue-600 mb-1 group-hover:scale-110 transition"></i>
                        <p class="font-semibold text-slate-700 text-sm">Add New Car</p>
                    </a>

                    <div class="max-h-[400px] overflow-y-auto pr-2 space-y-3 custom-scrollbar">
                        <% if (typeof cars !== 'undefined' && cars.length > 0) { %>
                            <% cars.forEach(car => { %>
                                <div class="flex items-center justify-between p-3 rounded-xl border border-slate-200 bg-slate-50 hover:bg-white transition shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <img src="<%= car.image %>" class="w-14 h-10 object-cover rounded-lg border border-slate-200 bg-white" alt="Car">
                                        <div>
                                            <p class="font-bold text-slate-800 text-sm leading-tight"><%= car.name %></p>
                                            <div class="flex gap-2 mt-1">
                                                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full uppercase <%= car.isDeleted ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-600' %>">
                                                    <%= car.isDeleted ? 'Inactive' : 'Active' %>
                                                </span>
                                                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full uppercase <%= car.isBooked ? 'bg-orange-100 text-orange-600' : 'bg-blue-100 text-blue-600' %>">
                                                    <%= car.isBooked ? 'Booked' : 'Available' %>
                                                </span>
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex gap-1">
                                        <a href="/car/edit/<%= car._id %>" class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition" title="Edit Car">
                                            <i data-lucide="edit-3" class="w-4 h-4"></i>
                                        </a>
                                        <% if (!car.isDeleted && !car.isBooked) { %>
                                            <form action="/car/delete" method="POST">
                                                <input type="hidden" name="id" value="<%= car._id %>">
                                                <button type="submit" class="p-2 text-red-500 hover:bg-red-100 rounded-lg transition" title="Delete Car">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/car/restore" method="POST">
                                                <input type="hidden" name="id" value="<%= car._id %>">
                                                <button type="submit" class="p-2 text-green-600 hover:bg-green-100 rounded-lg transition" title="Restore Car">
                                                    <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-slate-400 text-sm py-4">No cars in fleet.</p>
                        <% } %>
                    </div>
                </div>
            </section>

            <!-- Booking Requests -->
            <section class="bg-white p-6 rounded-2xl shadow-md border border-slate-200">
                <div class="flex items-center gap-2 mb-5">
                    <i data-lucide="calendar-check" class="text-orange-600"></i>
                    <h3 class="text-xl font-bold text-slate-800">Booking Management</h3>
                </div>

                <div class="space-y-4 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
                    <% if (typeof bookings !== 'undefined' && bookings.length > 0) { %>
                        <% bookings.forEach(booking => { %>
                            <div class="p-4 rounded-xl border <%= booking.status === 'pending' ? 'bg-blue-50 border-blue-100' : 'bg-slate-50 border-slate-200 shadow-sm' %>">
                                <!-- Header: ID & Status -->
                                <div class="flex justify-between items-start mb-3">
                                    <div>
                                        <p class="font-bold text-slate-800 text-sm">Order #<%= booking._id.toString().slice(-8).toUpperCase() %></p>
                                        <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider
                                            <%= booking.status === 'confirmed' ? 'bg-green-100 text-green-700' : 
                                                booking.status === 'pending' ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-700' %>">
                                            <%= booking.status %>
                                        </span>
                                    </div>
                                    <span class="text-[9px] font-bold px-2 py-0.5 bg-slate-200 text-slate-600 rounded-full uppercase"><%= booking.payment %></span>
                                </div>

                                <!-- Details: Car & User -->
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                                    <!-- Car Info -->
                                    <div class="flex gap-3">
                                        <img src="<%= booking.car.image %>" class="w-16 h-12 object-cover rounded-lg border border-slate-200 bg-white" alt="Car">
                                        <div class="text-xs">
                                            <p class="font-bold text-slate-800"><%= booking.car.name %></p>
                                            <p class="text-slate-500"><%= booking.car.model %> (<%= booking.car.modelYear %>)</p>
                                            <p class="text-blue-600 font-semibold">₹<%= booking.car.price %>/day</p>
                                        </div>
                                    </div>
                                    <!-- User Info -->
                                    <div class="text-xs">
                                        <p class="text-slate-400 uppercase font-bold text-[8px] mb-1">Customer</p>
                                        <p class="text-slate-800 font-bold"><%= booking.user ? booking.user.name : 'Unknown User' %></p>
                                        <p class="text-slate-500 truncate"><%= booking.user ? booking.user.email : 'N/A' %></p>
                                        <p class="text-indigo-600 font-medium mt-1">Date: <%= booking.date %></p>
                                    </div>
                                </div>

                                <!-- Actions: Only for pending -->
                                <% if (booking.status === 'pending') { %>
                                    <div class="flex gap-2 pt-3 border-t border-blue-100">
                                        <form action="/booking/approve" method="POST" class="flex-1">
                                            <input type="hidden" name="id" value="<%= booking._id %>">
                                            <button type="submit" class="w-full bg-green-600 text-white py-2 rounded-lg text-xs font-bold hover:bg-green-700 transition shadow-sm">
                                                Approve
                                            </button>
                                        </form>
                
                                        <form action="/booking/reject" method="POST" class="flex-1">
                                            <input type="hidden" name="id" value="<%= booking._id %>">
                                            <button type="submit" class="w-full bg-red-500 text-white py-2 rounded-lg text-xs font-bold hover:bg-red-600 transition shadow-sm">
                                                Reject
                                            </button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-6 text-slate-400 italic text-sm">
                            No bookings found in the system.
                        </div>
                    <% } %>
                </div>
            </section>

        </div>

    </main>

    <script>
        lucide.createIcons();
    </script>

</body>
</html>