<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookings Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-slate-100 min-h-screen">

    <!-- Navbar -->
    <nav class="bg-white shadow-md border-b border-slate-200 px-8 py-4">
        <div class="flex justify-between items-center max-w-7xl mx-auto">
            <div class="flex items-center gap-3">
                <i data-lucide="car-front" class="w-7 h-7 text-blue-600"></i>
                <h1 class="text-2xl font-bold text-slate-800">DriveSync Dashboard</h1>
            </div>

            <div class="flex items-center gap-5">
                <div class="flex items-center gap-2 text-slate-700">
                    <i data-lucide="user-circle" class="w-5 h-5"></i>
                    <span><%= user.name %></span>
                </div>

                <a href="/car/all"
                   class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                    <i data-lucide="warehouse" class="w-4 h-4"></i>
                    Go To Garage
                </a>

                <a href="/auth/logout"
                   class="flex items-center gap-2 bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main -->
    <main class="max-w-7xl mx-auto py-10 px-6">

        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-8 mb-8 border border-slate-200">
            <div class="flex items-center gap-3 mb-3">
                <i data-lucide="calendar-check" class="w-8 h-8 text-green-600"></i>
                <h2 class="text-3xl font-bold text-slate-800">My Booking Details</h2>
            </div>
            <p class="text-slate-500">All your active and previous bookings in one place.</p>
        </div>

        <!-- Booking Cards -->
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

            <% bookings.forEach(booking => { %>

                <div class="bg-white rounded-2xl shadow-md border border-slate-200 overflow-hidden hover:shadow-xl transition">

                    <!-- Car Image -->
                    <div class="h-52 overflow-hidden">
                        <img src="<%= booking.car.image %>"
                             class="w-full h-full object-cover"
                             alt="Car Image">
                    </div>

                    <!-- Details -->
                    <div class="p-6">

                        <div class="flex items-center gap-2 mb-3">
                            <i data-lucide="car" class="w-5 h-5 text-blue-600"></i>
                            <h3 class="text-xl font-bold text-slate-800">
                                <%= booking.car.name %>
                            </h3>
                        </div>

                        <div class="space-y-3 text-sm text-slate-600">

                            <div class="flex items-center gap-2">
                                <i data-lucide="badge-dollar-sign" class="w-4 h-4 text-green-600"></i>
                                ₹ <%= booking.car.price %> / day
                            </div>

                            <div class="flex items-center gap-2">
                                <i data-lucide="users" class="w-4 h-4 text-purple-600"></i>
                                <%= booking.car.seats %> Seats
                            </div>

                            <div class="flex items-center gap-2">
                                <i data-lucide="tag" class="w-4 h-4 text-orange-500"></i>
                                <span>Model: <%= booking.car.model %></span>
                            </div>

                            <div class="flex items-center gap-2">
                                <i data-lucide="calendar" class="w-4 h-4 text-blue-500"></i>
                                <span>Year: <%= booking.car.modelYear %></span>
                            </div>

                            <div class="flex items-center gap-2">
                                <i data-lucide="calendar-days" class="w-4 h-4 text-indigo-500"></i>
                                Booking Date: <%= booking.date %>
                            </div>

                            <div class="flex items-center gap-2">
                                <i data-lucide="shield-check" class="w-4 h-4 text-emerald-600"></i>
                                Status: 
                                <span class="font-semibold text-green-600">
                                    <%= booking.status %>
                                </span>
                            </div>

                        </div>

                        <!-- Footer -->
                        <div class="mt-5 pt-4 border-t border-slate-200 flex justify-between items-center">

                            <span class="text-xs text-slate-400">
                                Booking ID: <%= booking._id %>
                            </span>

                            <%if (booking.status === 'pending') { %>

                            <a href="/booking/details/<%= booking._id %>"
                               class="flex items-center gap-1 text-red-600 font-semibold hover:text-red-800">
                                <i data-lucide="delete"></i>
                                Cancel
                            </a>
                            
                            <% }%>
                            
                        </div>

                    </div>
                </div>

            <% }) %>

        </div>

    </main>

    <script>
        lucide.createIcons();
    </script>

</body>
</html>